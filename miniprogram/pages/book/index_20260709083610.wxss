.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  padding: 60rpx 48rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.book-content {
  padding: 48rpx;
}

.chapter-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.chapter-item {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  border: 3rpx solid transparent;
}

.chapter-item.active {
  background: #ffebee;
  border-color: #e74c3c;
}

.chapter-number {
  font-size: 24rpx;
  color: #e74c3c;
  font-weight: bold;
}

.chapter-title {
  font-size: 28rpx;
  color: #2c3e50;
}

.chapter-content {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx;
  min-height: 500rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.chapter-header {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #ecf0f1;
}

.chapter-body {
  font-size: 30rpx;
  color: #5a6c7d;
  line-height: 1.8;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #95a5a6;
}
