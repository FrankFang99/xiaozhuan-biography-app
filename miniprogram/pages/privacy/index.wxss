.privacy-container {
  min-height: 100vh;
  background-color: #f5f7fa;
  display: flex;
  flex-direction: column;
}

.privacy-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.privacy-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.privacy-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.privacy-content {
  flex: 1;
  padding: 40rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #d4a853;
}

.section-content {
  padding-left: 22rpx;
}

.para {
  display: block;
  font-size: 30rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 20rpx;
  text-align: justify;
}

.privacy-footer {
  padding: 40rpx;
  text-align: center;
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
}

.footer-text {
  font-size: 26rpx;
  color: #999999;
}
