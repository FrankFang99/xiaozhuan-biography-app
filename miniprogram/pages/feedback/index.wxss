.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #1a1a2e 100%);
  padding-bottom: 120rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 32rpx;
}

.header-left, .header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  font-size: 48rpx;
  color: #ffffff;
}

.header-title {
  font-size: 36rpx;
}

.content-scroll {
  height: calc(100vh - 200rpx);
  padding: 0 32rpx;
}

.feedback-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  margin-bottom: 20rpx;
  display: block;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  width: calc(50% - 10rpx);
  padding: 24rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.type-item.active {
  border-color: #d4a853;
  background: rgba(212, 168, 83, 0.2);
}

.type-icon {
  font-size: 40rpx;
}

.type-label {
  font-size: 26rpx;
  color: #ffffff;
}

.feedback-textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.05);
}

.feedback-textarea::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.contact-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.05);
}

.contact-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.context-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.toggle-info {
  flex: 1;
}

.toggle-title {
  font-size: 28rpx;
  display: block;
}

.toggle-desc {
  font-size: 22rpx;
  margin-top: 8rpx;
  display: block;
}

.toggle-switch {
  width: 88rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  position: relative;
  transition: all 0.3s ease;
}

.toggle-switch.on {
  background: #d4a853;
}

.toggle-thumb {
  width: 40rpx;
  height: 40rpx;
  background: #ffffff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: all 0.3s ease;
}

.toggle-switch.on .toggle-thumb {
  left: 44rpx;
}

.context-preview {
  padding: 24rpx;
  border-radius: 20rpx;
  max-height: 300rpx;
  overflow-y: auto;
}

.context-label {
  font-size: 22rpx;
  display: block;
  margin-bottom: 12rpx;
}

.context-content {
  font-size: 24rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, rgba(10, 10, 26, 0.95) 30%);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #d4a853 0%, #b89444 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn::after {
  border: none;
}

.btn-text {
  font-size: 32rpx;
  color: #0a0a1a;
  font-weight: bold;
}