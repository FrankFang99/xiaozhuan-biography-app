.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #030512 0%, #070b1f 30%, #0c122e 60%, #121a3d 100%);
  padding: 40rpx;
  padding-bottom: 200rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.header-title {
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
  text-shadow: 0 0 40rpx rgba(212, 168, 83, 0.4);
}

.header-desc {
  margin-bottom: 40rpx;
}

.desc-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stories-section {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.story-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 40rpx;
  transition: all 0.3s ease;
}

.story-card:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.12);
}

.story-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 28rpx;
}

.story-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(212, 168, 83, 0.4);
  overflow: hidden;
}

.story-avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #d4a853;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.story-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.story-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.story-bio {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.story-tag {
  background: rgba(212, 168, 83, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
}

.tag-text {
  font-size: 28rpx;
  color: #d4a853;
  font-weight: 500;
}

.story-preview {
  margin-bottom: 24rpx;
}

.preview-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.story-stats {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clock-outline {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #d4a853;
  border-radius: 50%;
  position: relative;
}

.clock-hand {
  position: absolute;
  width: 2rpx;
  height: 14rpx;
  background: #d4a853;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -100%);
  border-radius: 2rpx;
}

.book-icon {
  width: 36rpx;
  height: 40rpx;
  position: relative;
}

.book-spine {
  position: absolute;
  width: 6rpx;
  height: 100%;
  left: 0;
  background: #d4a853;
  border-radius: 2rpx;
}

.book-page {
  position: absolute;
  width: 28rpx;
  height: 100%;
  left: 8rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 0 4rpx 4rpx 0;
}

.stat-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
}

.action-area {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-secondary {
  width: 100%;
  padding: 36rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.btn-text-secondary {
  font-size: 38rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
}

.btn-primary {
  width: 100%;
  padding: 40rpx;
  background: linear-gradient(135deg, #c73e3a, #e74c3c, #f16c5f);
  border-radius: 24rpx;
  border: none;
}

.btn-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.story-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 90vh;
  background: linear-gradient(180deg, #0c122e 0%, #070b1f 100%);
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-header {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 40rpx;
}

.modal-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(212, 168, 83, 0.4);
  overflow: hidden;
}

.modal-avatar-image {
  width: 100%;
  height: 100%;
}

.modal-avatar-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #d4a853;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.modal-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.modal-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
}

.modal-bio {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.6);
}

.close-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.close-line {
  position: absolute;
  width: 36rpx;
  height: 3rpx;
  background: rgba(255, 255, 255, 0.6);
  top: 50%;
  left: 50%;
}

.close-line-1 {
  transform: translate(-50%, -50%) rotate(45deg);
}

.close-line-2 {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.modal-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: rgba(212, 168, 83, 0.2);
}

.tab-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.6);
}

.tab-item.active .tab-text {
  color: #d4a853;
  font-weight: 600;
}

.modal-content-area {
  height: 60vh;
}

.chapter-card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.chapter-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.chapter-number {
  width: 56rpx;
  height: 56rpx;
  background: rgba(212, 168, 83, 0.2);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #d4a853;
}

.chapter-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.chapter-excerpt {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.chapter-word-count {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

.full-chapter {
  margin-bottom: 48rpx;
}

.full-chapter-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  display: block;
}

.full-chapter-content {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.8;
  display: block;
}

.family-card {
  background: rgba(231, 76, 60, 0.1);
  border-radius: 24rpx;
  padding: 36rpx;
}

.family-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #e74c3c;
  margin-bottom: 20rpx;
  display: block;
}

.family-content {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.7;
  display: block;
}
