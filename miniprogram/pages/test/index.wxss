.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #030512 0%, #070b1f 100%);
  padding: 32rpx;
  padding-bottom: 40rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.panel {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
}

.panel-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.sample-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.sample-item {
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.sample-item.active {
  background: rgba(212, 168, 83, 0.2);
  border-color: rgba(212, 168, 83, 0.5);
}

.sample-name {
  font-size: 28rpx;
  color: #ffffff;
  display: block;
}

.sample-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.conversation-scroll {
  max-height: 500rpx;
}

.conversation-item {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.turn-badge {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #d4a853, #e5c06f);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #030512;
  margin-bottom: 16rpx;
}

.ai-message, .user-message {
  margin-bottom: 12rpx;
}

.message-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 8rpx;
}

.message-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.action-area {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #c73e3a, #e74c3c);
  color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-secondary {
  flex: 1;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.score-badge {
  display: flex;
  align-items: baseline;
}

.score-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #e5c06f;
}

.score-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.score-details {
  margin-bottom: 24rpx;
}

.score-item {
  margin-bottom: 20rpx;
}

.score-label {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.score-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-num {
  font-size: 28rpx;
  color: #e5c06f;
  font-weight: 600;
}

.score-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #d4a853, #e5c06f);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.score-comment {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  display: block;
}

.evaluation-summary {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 12rpx;
}

.summary-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.evaluation-lists {
  display: flex;
  gap: 32rpx;
}

.list-section {
  flex: 1;
}

.list-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 12rpx;
}

.list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.list-dot {
  color: #e5c06f;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.list-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.biography-scroll {
  max-height: 800rpx;
}

.biography-section {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 12rpx;
}

.section-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}

.chapter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.chapter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.chapter-year {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.chapter-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.chapter-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.chapter-quote {
  font-size: 26rpx;
  color: #e5c06f;
  font-style: italic;
}

.chapter-emotion {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  background: rgba(212, 168, 83, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.history-scroll {
  max-height: 400rpx;
}

.empty-history {
  text-align: center;
  padding: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
}

.history-item {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.history-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #e5c06f;
}

.history-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

.history-comment {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}