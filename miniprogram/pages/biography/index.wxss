.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #030512 0%, #070b1f 100%);
}

.universe-view {
  height: 100vh;
  position: relative;
  background: #030512;
}

.universe-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  text-align: center;
  padding: 80rpx 48rpx 40rpx;
  background: linear-gradient(180deg, rgba(3, 5, 18, 0.95) 0%, rgba(3, 5, 18, 0.8) 80%, transparent 100%);
}

.universe-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
  text-shadow: 0 0 40rpx rgba(212, 168, 83, 0.4);
  display: block;
  margin-bottom: 12rpx;
}

.universe-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.universe-scroll {
  width: 100%;
  height: 100%;
  position: relative;
}

.universe-canvas {
  width: 200%;
  height: 200%;
  position: relative;
}

.universe-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at center, #0a1635 0%, #030512 50%, #000000 100%);
}

.person-star {
  position: absolute;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
}

.star-core {
  position: absolute;
  width: 40%;
  height: 40%;
  border-radius: 50%;
  box-shadow: 0 0 30rpx currentColor;
  animation: starPulse 3s ease-in-out infinite;
}

.star-ring {
  position: absolute;
  width: 80%;
  height: 80%;
  border: 3rpx solid;
  border-radius: 50%;
  opacity: 0.6;
  animation: starRotate 8s linear infinite;
}

.star-glow {
  position: absolute;
  width: 150%;
  height: 150%;
  border-radius: 50%;
  opacity: 0.15;
  filter: blur(20rpx);
  animation: starGlow 4s ease-in-out infinite;
}

.star-avatar {
  position: relative;
  z-index: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

@keyframes starPulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.2); opacity: 1; }
}

@keyframes starRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes starGlow {
  0%, 100% { opacity: 0.1; transform: scale(1); }
  50% { opacity: 0.25; transform: scale(1.1); }
}

.star-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.popup-content {
  width: 100%;
  max-width: 600rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 32rpx;
  padding: 56rpx 48rpx;
  position: relative;
  border: 2rpx solid rgba(212, 168, 83, 0.3);
}

.popup-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(212, 168, 83, 0.6);
  overflow: hidden;
  margin: 0 auto 32rpx;
}

.popup-avatar-image {
  width: 100%;
  height: 100%;
}

.popup-avatar .avatar-text {
  font-size: 64rpx;
}

.popup-avatar-initial {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #d4a853 0%, #c73e3a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
}

.popup-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
  display: block;
  margin-bottom: 12rpx;
}

.popup-bio {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  display: block;
  margin-bottom: 32rpx;
}

.popup-intro {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.7;
  text-align: center;
  display: block;
  margin-bottom: 40rpx;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.popup-btn {
  width: 100%;
  padding: 36rpx;
  background: linear-gradient(135deg, #d4a853, #e5c06f);
  border-radius: 24rpx;
  border: none;
}

.popup-btn-text {
  font-size: 38rpx;
  font-weight: 600;
  color: #030512;
}

.popup-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.close-line {
  position: absolute;
  width: 36rpx;
  height: 3rpx;
  background: rgba(255, 255, 255, 0.6);
  top: 50%;
  left: 50%;
}

.close-line-1 {
  transform: translate(-50%, -50%) rotate(45deg);
}

.close-line-2 {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.nav-icon-close {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.nav-icon-close .close-line {
  width: 28rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.8);
}

.nav-icon-menu {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.menu-line {
  width: 28rpx;
  height: 3rpx;
  background: rgba(255, 255, 255, 0.8);
  margin-bottom: 6rpx;
}

.menu-line:last-child {
  margin-bottom: 0;
}

.book-cover {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.cover-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #030512 0%, #0c122e 50%, #1a1a2e 100%);
}

.stars-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.bg-star {
  position: absolute;
  animation: twinkle infinite ease-in-out;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-dot {
  width: 100%;
  height: 100%;
  background: #ffffff;
  border-radius: 50%;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

.cover-content {
  position: relative;
  z-index: 1;
  padding: 120rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cover-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(212, 168, 83, 0.6);
  overflow: hidden;
  margin-bottom: 48rpx;
}

.cover-avatar-image {
  width: 100%;
  height: 100%;
}

.cover-avatar-initial {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #d4a853 0%, #c73e3a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-avatar-text {
  font-size: 80rpx;
  font-weight: bold;
  color: #ffffff;
}

.avatar-text {
  font-size: 80rpx;
  font-weight: bold;
  color: #d4a853;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.cover-title {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
  margin-bottom: 24rpx;
}

.cover-subtitle {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.cover-date {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 48rpx;
}

.cover-decoration {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.cover-decoration .line {
  width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d4a853);
}

.diamond {
  width: 24rpx;
  height: 24rpx;
  background: #d4a853;
  transform: rotate(45deg);
  box-shadow: 0 0 20rpx rgba(212, 168, 83, 0.6);
}

.cover-tag {
  font-size: 32rpx;
  color: #d4a853;
  background: rgba(212, 168, 83, 0.15);
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
  margin-bottom: 80rpx;
}

.open-book-btn {
  position: relative;
  z-index: 1;
  padding: 36rpx 80rpx;
  background: linear-gradient(135deg, #d4a853, #e5c06f);
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 auto;
  box-shadow: 0 10rpx 40rpx rgba(212, 168, 83, 0.4);
}

.open-book-btn .btn-text {
  font-size: 38rpx;
  font-weight: 600;
  color: #030512;
}

.open-book-btn .arrow {
  font-size: 40rpx;
  color: #030512;
  animation: arrowMove 1.5s ease-in-out infinite;
}

@keyframes arrowMove {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(10rpx); }
}

.book-content {
  height: 100vh;
  padding: 48rpx;
  padding-bottom: 200rpx;
}

.book-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 40rpx;
}

.book-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
  display: block;
  margin-bottom: 12rpx;
}

.book-subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.timeline-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #d4a853;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-calendar {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.icon-calendar::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 70%;
  background: #d4a853;
  border-radius: 6rpx 6rpx 0 0;
  top: 0;
}

.icon-calendar::after {
  content: '';
  position: absolute;
  width: 100%;
  height: 30%;
  background: rgba(212, 168, 83, 0.5);
  border-radius: 0 0 6rpx 6rpx;
  bottom: 0;
}

.timeline-scroll {
  white-space: nowrap;
}

.timeline-container {
  display: inline-flex;
  gap: 16rpx;
  padding: 20rpx 0;
}

.timeline-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 160rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  background: #d4a853;
  border-radius: 50%;
  margin-bottom: 12rpx;
  box-shadow: 0 0 12rpx rgba(212, 168, 83, 0.6);
}

.timeline-content {
  text-align: center;
}

.timeline-year {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.timeline-event {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 140rpx;
}

.book-intro {
  margin-bottom: 40rpx;
  padding: 40rpx;
}

.intro-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #d4a853;
  margin-bottom: 24rpx;
  display: block;
}

.intro-content {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.8;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.chapter-section {
  margin-bottom: 56rpx;
}

.chapter-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.chapter-number-box {
  width: 72rpx;
  height: 72rpx;
  background: rgba(212, 168, 83, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chapter-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #d4a853;
}

.chapter-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chapter-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.chapter-year {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.emotion-tag {
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.emotion-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.photo-placeholder {
  margin-bottom: 24rpx;
}

.photo-frame {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04));
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.photo-icon {
  width: 200rpx;
  height: 160rpx;
  position: relative;
  margin-bottom: 16rpx;
}

.frame-corner {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #d4a853;
}

.frame-corner-tl {
  top: 0;
  left: 0;
  border-right: none;
  border-bottom: none;
  border-radius: 8rpx 0 0 0;
}

.frame-corner-tr {
  top: 0;
  right: 0;
  border-left: none;
  border-bottom: none;
  border-radius: 0 8rpx 0 0;
}

.frame-corner-bl {
  bottom: 0;
  left: 0;
  border-right: none;
  border-top: none;
  border-radius: 0 0 0 8rpx;
}

.frame-corner-br {
  bottom: 0;
  right: 0;
  border-left: none;
  border-top: none;
  border-radius: 0 0 8rpx 0;
}

.photo-inner {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  background: rgba(212, 168, 83, 0.1);
  border-radius: 8rpx;
}

.photo-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.photo-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.chapter-content {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 24rpx;
  padding: 40rpx;
}

.content-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.9;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.chapter-quote {
  margin-top: 32rpx;
  padding: 36rpx;
  background: rgba(212, 168, 83, 0.12);
  border-left: 6rpx solid #d4a853;
  border-radius: 0 24rpx 24rpx 0;
}

.quote-icon {
  font-size: 48rpx;
  color: #d4a853;
  line-height: 0.5;
  display: block;
  margin-bottom: 12rpx;
}

.quote-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.85);
  font-style: italic;
  line-height: 1.7;
  display: block;
}

.quote-author {
  font-size: 28rpx;
  color: #d4a853;
  margin-top: 16rpx;
  display: block;
}

.book-footer {
  margin-bottom: 40rpx;
  padding: 40rpx;
}

.footer-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #d4a853;
  margin-bottom: 24rpx;
  display: block;
}

.footer-content {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.8;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
  margin-bottom: 32rpx;
  display: block;
}

.footer-family {
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.family-label {
  font-size: 32rpx;
  color: #e74c3c;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.icon-letter {
  width: 36rpx;
  height: 28rpx;
  position: relative;
}

.icon-letter::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 70%;
  background: #e74c3c;
  border-radius: 4rpx;
  top: 0;
}

.icon-letter::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-top: 18rpx solid #e74c3c;
  bottom: 0;
  left: 0;
}

.family-content {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.7;
}

.book-end {
  text-align: center;
  padding: 60rpx 0;
}

.end-decoration {
  margin-bottom: 24rpx;
}

.end-decoration .diamond {
  width: 32rpx;
  height: 32rpx;
  margin: 0 auto;
}

.end-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 16rpx;
}

.end-author {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.2);
}

.nav-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(7, 11, 31, 0.95);
  backdrop-filter: blur(30rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 24rpx 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.nav-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

.nav-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.nav-indicator {
  padding: 16rpx 32rpx;
  background: rgba(212, 168, 83, 0.2);
  border-radius: 32rpx;
}

.indicator-text {
  font-size: 30rpx;
  color: #d4a853;
}

.toc-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toc-content {
  width: 85%;
  max-height: 70%;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 32rpx;
  border: 2rpx solid rgba(212, 168, 83, 0.3);
  overflow: hidden;
}

.toc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.toc-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
}

.toc-close {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.toc-list {
  height: 60vh;
  padding: 20rpx;
}

.toc-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  transition: all 0.3s ease;
}

.toc-item.active {
  background: rgba(212, 168, 83, 0.2);
}

.toc-number {
  font-size: 32rpx;
  color: #d4a853;
  margin-right: 24rpx;
  font-weight: 600;
}

.toc-chapter {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.toc-item.active .toc-chapter {
  color: #ffffff;
}

.story-selector {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.selector-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.selector-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #0c122e 0%, #070b1f 100%);
  border-radius: 48rpx 48rpx 0 0;
  padding: 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.selector-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 32rpx;
  display: block;
  text-align: center;
}

.selector-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.selector-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.selector-item.active {
  background: rgba(212, 168, 83, 0.2);
  border: 1rpx solid rgba(212, 168, 83, 0.3);
}

.selector-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(212, 168, 83, 0.4);
  overflow: hidden;
}

.selector-avatar-image {
  width: 100%;
  height: 100%;
}

.selector-avatar-initial {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #d4a853 0%, #c73e3a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.selector-avatar-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.selector-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.selector-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.selector-bio {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
}

.glass-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
}
