.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #030512 0%, #070b1f 30%, #0c122e 60%, #121a3d 100%);
  padding: 48rpx 36rpx;
  padding-bottom: 240rpx;
}

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #030512 0%, #070b1f 30%, #0c122e 60%, #121a3d 100%);
  padding: 48rpx 36rpx;
  padding-bottom: 240rpx;
}

.header {
  margin-bottom: 36rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 32rpx;
}

.header-count {
  position: absolute;
  right: 48rpx;
  top: 60rpx;
  text-align: right;
}

.count-number {
  font-size: 64rpx;
  font-weight: bold;
  color: #d4a853;
}

.count-label {
  font-size: 28rpx;
}

.progress-card {
  margin-bottom: 36rpx;
}

.progress-bar {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #d4a853, #e5c06f);
  border-radius: 32rpx;
  transition: width 0.5s ease;
}

.biography-card {
  margin-bottom: 36rpx;
  padding: 32rpx;
}

.biography-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.biography-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}

.biography-icon.icon-book::before {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 56rpx;
  border: 4rpx solid #d4a853;
  border-radius: 4rpx;
  top: 0;
  left: 4rpx;
}

.biography-icon.icon-book::after {
  content: '';
  position: absolute;
  width: 4rpx;
  height: 56rpx;
  background: #d4a853;
  top: 0;
  left: 26rpx;
}

.biography-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.biography-title {
  font-size: 36rpx;
}

.biography-status {
  font-size: 28rpx;
}

.biography-preview {
  font-size: 28rpx;
}

.letter-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.letter-item {
  padding: 36rpx;
  transition: all 0.3s ease;
}

.letter-item:active {
  transform: scale(0.98);
}

.letter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.letter-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.letter-chapter {
  font-size: 28rpx;
  color: #d4a853;
}

.letter-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.letter-preview {
  font-size: 32rpx;
  line-height: 1.6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon-container {
  margin-bottom: 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  position: relative;
}

.empty-icon.icon-empty::before {
  content: '';
  position: absolute;
  width: 100rpx;
  height: 88rpx;
  border: 6rpx solid #d4a853;
  border-radius: 8rpx;
  top: 16rpx;
  left: 10rpx;
}

.empty-icon.icon-empty::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 56rpx;
  background: #d4a853;
  top: 28rpx;
  left: 57rpx;
  transform: rotate(-20deg);
}

.empty-text {
  font-size: 36rpx;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 32rpx;
}

.fab {
  position: fixed;
  bottom: 240rpx;
  right: 48rpx;
  background: linear-gradient(135deg, #e74c3c, #c73e3a);
  color: #ffffff;
  border-radius: 50%;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 10rpx 40rpx rgba(231, 76, 60, 0.5);
}

.fab-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}

.fab-icon.icon-write::before {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 40rpx;
  border: 4rpx solid #ffffff;
  border-radius: 4rpx;
  top: 8rpx;
  left: 4rpx;
}

.fab-icon.icon-write::after {
  content: '';
  position: absolute;
  width: 4rpx;
  height: 32rpx;
  background: #ffffff;
  top: 16rpx;
  left: 26rpx;
  transform: rotate(-20deg);
}

.fab-text {
  font-size: 24rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  overflow: hidden;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx;
  padding-bottom: 80rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.modal-close {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.close-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.close-icon::before,
.close-icon::after {
  content: '';
  position: absolute;
  width: 44rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.6);
  top: 16rpx;
  left: -4rpx;
}

.close-icon::before {
  transform: rotate(45deg);
}

.close-icon::after {
  transform: rotate(-45deg);
}

.modal-body {
  max-height: 70vh;
}

.chapter-text {
  font-size: 34rpx;
  color: #ffffff;
  line-height: 2;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}
