<view class="container">
  <view class="stars-bg">
    <view 
      wx:for="{{stars}}" 
      wx:key="id" 
      class="star"
      style="left: {{item.x}}%; top: {{item.y}}%; opacity: {{item.opacity}}; animation-duration: {{item.duration}}s;"
      bindtap="onStarTap"
      data-star="{{item}}"
    >
      <text class="star-icon">⭐</text>
    </view>
  </view>

  <view class="header">
    <text class="title">星空纪念</text>
    <text class="subtitle">每颗星星，都是一段永恒的记忆</text>
  </view>

  <view class="star-list">
    <view 
      wx:for="{{stars}}" 
      wx:key="id" 
      class="star-card"
      bindtap="onStarTap"
      data-star="{{item}}"
    >
      <view class="star-avatar" style="background: {{item.status === 'alive' ? '#e74c3c' : '#7f8c8d'}}">
        <text class="star-emoji">{{item.emoji}}</text>
      </view>
      <view class="star-info">
        <text class="star-name">{{item.name}}</text>
        <text class="star-status">{{item.status === 'alive' ? '在世' : '已逝去'}}</text>
      </view>
      <view class="star-birthday">
        <text class="birthday-text">{{item.birthday}}</text>
      </view>
    </view>
  </view>

  <view class="modal" wx:if="{{showModal}}" bindtap="onCloseModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-avatar" style="background: {{selectedStar.status === 'alive' ? '#e74c3c' : '#7f8c8d'}}">
          <text class="modal-emoji">{{selectedStar.emoji}}</text>
        </view>
        <text class="modal-name">{{selectedStar.name}}</text>
      </view>
      <view class="modal-body">
        <text class="modal-status">{{selectedStar.status === 'alive' ? '🌟 在世' : '💫 已逝去'}}</text>
        <text class="modal-birthday">生日：{{selectedStar.birthday}}</text>
        <text class="modal-message">{{selectedStar.message}}</text>
      </view>
      <button class="modal-close" bindtap="onCloseModal">关闭</button>
    </view>
  </view>
</view>
