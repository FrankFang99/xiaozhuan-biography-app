.container {
  min-height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
}

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef2f7 0%, #f5f7fa 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
}

.page-container.font-large .message-text {
  font-size: 48rpx;
}

.page-container.font-large .input {
  font-size: 48rpx;
}

.page-container.font-large .voice-text {
  font-size: 48rpx;
}

.page-container.font-large .suggestion-text {
  font-size: 36rpx;
}

.page-container.font-large .chat-title {
  font-size: 52rpx;
}

.page-container.font-large .chat-status {
  font-size: 38rpx;
}

.page-container.font-small .message-text {
  font-size: 32rpx;
}

.page-container.font-small .input {
  font-size: 32rpx;
}

.page-container.font-small .voice-text {
  font-size: 32rpx;
}

.page-container.font-small .suggestion-text {
  font-size: 24rpx;
}

.chat-header {
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  overflow: hidden;
}

.chat-header.header-hidden {
  max-height: 0;
  opacity: 0;
  padding-top: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.chat-header-content {
  display: flex;
  align-items: center;
  gap: 32rpx;
  justify-content: space-between;
}

.chat-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 12rpx;
  background: rgba(212, 168, 83, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.chat-avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.chat-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.font-size-btn {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.font-size-icon {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.font-size-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #d4a853;
  line-height: 1;
}

.font-size-text-sm {
  font-size: 22rpx;
  font-weight: bold;
  color: rgba(0, 0, 0, 0.6);
  line-height: 1;
}

.chat-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.chat-status {
  font-size: 32rpx;
  color: #d4a853;
}

.chat-phase {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-top: 24rpx;
}

.phase-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.phase-dot.active {
  width: 24rpx;
  height: 24rpx;
  background: #d4a853;
}

.phase-line {
  width: 60rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 2rpx;
}

.progress-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.6);
}

.progress-percent {
  font-size: 32rpx;
  font-weight: bold;
  color: #d4a853;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #d4a853, #c73e3a);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-detail {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.progress-count {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.4);
}

.progress-days {
  font-size: 26rpx;
  color: #e74c3c;
}

.float-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 100;
  background: rgba(255, 255, 255, 0.98);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
  transform: translateY(-100%);
  opacity: 0;
  transition: all 0.3s ease;
}

.float-header.show {
  transform: translateY(0);
  opacity: 1;
}

.float-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: rgba(212, 168, 83, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.float-avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.float-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.float-stage {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.float-progress-bar {
  height: 8rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.float-progress-fill {
  height: 100%;
  background: #d4a853;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.float-progress-text {
  font-size: 24rpx;
  color: #666666;
}

.float-font-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.float-font-icon {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.float-font-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1;
}

.notification-area {
  margin: 28rpx 40rpx;
  padding: 32rpx;
}

.notification-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.notification-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.notification-type {
  font-size: 34rpx;
  font-weight: 600;
}

.notification-text {
  font-size: 34rpx;
}

.notification-time {
  font-size: 28rpx;
}

.notification-clear {
  font-size: 30rpx;
  text-align: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  color: rgba(0, 0, 0, 0.4);
}

.message-list {
  padding: 40rpx;
  padding-bottom: 280rpx;
  overflow: hidden;
}

.question-suggestions-area {
  margin-top: 40rpx;
}

.question-suggestions {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 20rpx;
}

.suggestions-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.ai-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
}

.avatar-image-small {
  width: 100%;
  height: 100%;
}

.suggestions-title {
  font-size: 32rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.8);
  flex: 1;
}

.change-question-btn {
  padding: 12rpx 24rpx;
  background: rgba(212, 168, 83, 0.2);
  border-radius: 24rpx;
}

.change-btn-text {
  font-size: 28rpx;
  color: #d4a853;
}

.suggestions-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.suggestion-item {
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.suggestion-text {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.8);
}

.scroll-bottom-anchor {
  height: 40rpx;
  width: 100%;
}

.message-item {
  display: flex;
  gap: 28rpx;
  margin-bottom: 48rpx;
}

.message-item.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  flex-shrink: 0;
}

.avatar.ai {
  background: rgba(212, 168, 83, 0.2);
  border: 2rpx solid rgba(212, 168, 83, 0.3);
}

.avatar.user {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-default {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #95ec69 0%, #73d13d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-initial {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.avatar-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #d4a853;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.message-content {
  max-width: 75%;
}

.message-text {
  font-size: 40rpx;
  line-height: 1.7;
  padding: 32rpx 40rpx;
  border-radius: 32rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.message-item.user .message-text {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  border-radius: 32rpx 12rpx 32rpx 32rpx;
}

.message-item.ai .message-text {
  background: rgba(255, 255, 255, 0.9);
  color: rgba(0, 0, 0, 0.9);
  border-radius: 12rpx 32rpx 32rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.message-time {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.4);
  display: block;
  margin-top: 16rpx;
}

.message-item.user .message-time {
  text-align: right;
}

.loading-dots {
  display: flex;
  gap: 20rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 12rpx 32rpx 32rpx 32rpx;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  background: #d4a853;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.input-area {
  padding: 32rpx;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.98);
  align-items: center;
}

.voice-input-area {
  flex: 1;
  display: flex;
  justify-content: center;
}

.voice-btn {
  width: 100%;
  padding: 40rpx;
  background: rgba(231, 76, 60, 0.15);
  border-radius: 56rpx;
  border: 2rpx solid rgba(231, 76, 60, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  transition: all 0.3s ease;
}

.voice-btn:active {
  transform: scale(0.98);
}

.voice-btn.recording {
  background: rgba(231, 76, 60, 0.3);
  border-color: #e74c3c;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(231, 76, 60, 0.4); }
  50% { box-shadow: 0 0 0 20rpx rgba(231, 76, 60, 0); }
}

.voice-icon {
  width: 64rpx;
  height: 64rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mic {
  width: 28rpx;
  height: 48rpx;
  background: #e74c3c;
  border-radius: 14rpx 14rpx 24rpx 24rpx;
  position: relative;
}

.mic::before {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #e74c3c;
  border-radius: 50%;
  top: -28rpx;
  left: 2rpx;
}

.voice-icon.recording .mic {
  display: none;
}

.recording-wave {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 48rpx;
}

.wave-bar {
  width: 10rpx;
  background: #e74c3c;
  border-radius: 5rpx;
  animation: wave 1s infinite ease-in-out;
}

.wave-bar:nth-child(1) { animation-delay: 0s; height: 20rpx; }
.wave-bar:nth-child(2) { animation-delay: 0.1s; height: 28rpx; }
.wave-bar:nth-child(3) { animation-delay: 0.2s; height: 40rpx; }
.wave-bar:nth-child(4) { animation-delay: 0.3s; height: 28rpx; }
.wave-bar:nth-child(5) { animation-delay: 0.4s; height: 20rpx; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1); }
}

.test-btn {
  margin-left: 20rpx;
  padding: 8rpx 16rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
}

.test-btn-text {
  font-size: 26rpx;
  color: #667eea;
}

.test-elders-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.test-elders-modal {
  width: 600rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.test-elders-header {
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.test-elders-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.test-elders-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-text {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.test-elders-list {
  flex: 1;
  padding: 20rpx;
  max-height: 60vh;
}

.elder-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #f8f9fb;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.elder-item.selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

.elder-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.elder-avatar-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.elder-info {
  flex: 1;
  margin-left: 20rpx;
  margin-right: 20rpx;
}

.elder-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.elder-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.elder-age {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.5);
}

.elder-background {
  font-size: 28rpx;
  color: #667eea;
  display: block;
  margin-bottom: 8rpx;
}

.elder-desc {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.6);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.elder-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.test-elders-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.start-test-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.start-test-btn[disabled] {
  background: #cccccc;
}

.start-btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.voice-text {
  font-size: 40rpx;
  color: #e74c3c;
  font-weight: 500;
}

.text-input-area {
  flex: 1;
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.input {
  flex: 1;
  padding: 32rpx 40rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 56rpx;
  font-size: 40rpx;
  color: #333333;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

.input-placeholder {
  color: rgba(0, 0, 0, 0.3);
}

.send-btn {
  padding: 32rpx 64rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  border-radius: 56rpx;
  font-size: 40rpx;
  font-weight: 600;
  border: none;
}

.send-btn[disabled] {
  background: rgba(0, 0, 0, 0.1);
  color: rgba(0, 0, 0, 0.3);
}

.mode-toggle {
  width: 96rpx;
  height: 96rpx;
  background: rgba(0, 0, 0, 0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.toggle-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}

.icon-text {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #d4a853;
  border-radius: 6rpx;
  position: relative;
}

.icon-text::before {
  content: '';
  position: absolute;
  width: 28rpx;
  height: 4rpx;
  background: #d4a853;
  top: 12rpx;
  left: 6rpx;
  box-shadow: 0 10rpx 0 #d4a853;
}

.icon-mic {
  width: 24rpx;
  height: 40rpx;
  background: #d4a853;
  border-radius: 12rpx 12rpx 20rpx 20rpx;
  position: relative;
}

.icon-mic::before {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid #d4a853;
  border-radius: 50%;
  top: -24rpx;
  left: 2rpx;
}

.tutorial-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tutorial-content {
  width: 80%;
  max-width: 600rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  border: 2rpx solid rgba(212, 168, 83, 0.3);
}

.tutorial-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 40rpx;
  background: rgba(231, 76, 60, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tutorial-mic {
  width: 48rpx;
  height: 80rpx;
  background: #e74c3c;
  border-radius: 24rpx 24rpx 40rpx 40rpx;
  position: relative;
}

.tutorial-mic::before {
  content: '';
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border: 6rpx solid #e74c3c;
  border-radius: 50%;
  top: -40rpx;
  left: 4rpx;
}

.tutorial-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.tutorial-desc {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 40rpx;
}

.tutorial-hand {
  width: 120rpx;
  height: 160rpx;
  margin: 0 auto 40rpx;
  position: relative;
  animation: press 2s infinite;
}

@keyframes press {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(30rpx); }
}

.finger {
  width: 40rpx;
  height: 100rpx;
  background: linear-gradient(90deg, #d4a853, #e5c06f);
  border-radius: 20rpx 20rpx 20rpx 20rpx;
  margin: 0 auto;
}

.finger::before {
  content: '';
  position: absolute;
  width: 56rpx;
  height: 40rpx;
  background: linear-gradient(90deg, #d4a853, #e5c06f);
  border-radius: 28rpx;
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
}

.tutorial-close-btn {
  width: 100%;
  padding: 36rpx;
  background: linear-gradient(135deg, #e74c3c, #c73e3a);
  color: #333333;
  border-radius: 24rpx;
  font-size: 40rpx;
  font-weight: 600;
  border: none;
}