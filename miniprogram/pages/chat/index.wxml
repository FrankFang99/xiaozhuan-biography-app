<view class="page-container font-{{fontSize}}">
  <view class="chat-header {{showFloatHeader ? 'header-hidden' : ''}}">
    <view class="chat-header-content">
      <view class="chat-avatar">
        <image class="chat-avatar-image" src="/images/biographer_avatar.jpg" mode="aspectFill" />
      </view>
      <view class="chat-info">
        <text class="chat-title font-serif">小传</text>
        <text class="chat-status text-gold">{{stageName}}</text>
      </view>
      <view class="header-actions">
        <view class="font-size-btn" bindtap="onToggleFontSize">
          <view class="font-size-icon">
            <text class="font-size-text">A</text>
            <text class="font-size-text-sm">A</text>
          </view>
        </view>
        <view class="test-btn" bindtap="onShowTestElders">
          <text class="test-btn-text">测试</text>
        </view>
      </view>
    </view>
    <view class="chat-phase">
      <view class="phase-dot {{conversationPhase === 'trust_building' ? 'active' : ''}}"></view>
      <view class="phase-line"></view>
      <view class="phase-dot {{conversationPhase === 'interest_exploration' ? 'active' : ''}}"></view>
      <view class="phase-line"></view>
      <view class="phase-dot {{conversationPhase === 'deep_collection' ? 'active' : ''}}"></view>
    </view>
    <view wx:if="{{progressPercent > 0}}" class="progress-section">
      <view class="progress-info">
        <text class="progress-text">传记进度</text>
        <text class="progress-percent">{{progressPercent}}%</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
      <view class="progress-detail">
        <text class="progress-count">{{currentLetterCount}}/{{targetLetterCount}}封信件</text>
        <text wx:if="{{daysRemaining > 0}}" class="progress-days">预计剩余{{daysRemaining}}天</text>
      </view>
    </view>
  </view>

  <view class="float-header {{showFloatHeader ? 'show' : ''}}">
    <view class="float-avatar">
      <image class="float-avatar-image" src="/images/biographer_avatar.jpg" mode="aspectFill" />
    </view>
    <view class="float-info">
      <text class="float-stage">{{stageName}}</text>
      <view wx:if="{{progressPercent > 0}}" class="float-progress-bar">
        <view class="float-progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
      <text wx:if="{{progressPercent > 0}}" class="float-progress-text">{{progressPercent}}%</text>
    </view>
    <view class="float-font-btn" bindtap="onToggleFontSize">
      <view class="float-font-icon">
        <text class="float-font-text">A</text>
      </view>
    </view>
  </view>

  <view wx:if="{{hasNotification}}" class="notification-area" bindtap="onClearNotification">
    <view class="notification-list">
      <view wx:for="{{notifications}}" wx:key="id" class="notification-item">
        <text class="notification-type text-gold">{{item.type}}</text>
        <text class="notification-text text-ghost-gray">{{item.text}}</text>
        <text class="notification-time text-ghost-faint">{{item.time}}</text>
      </view>
    </view>
    <text class="notification-clear text-ghost-muted">点击清空</text>
  </view>

  <scroll-view class="message-list" scroll-y scroll-into-view="{{scrollToId}}" style="height: {{scrollHeight}}px;" enhanced bindscroll="onScroll">
    <view 
      wx:for="{{messages}}" 
      wx:key="id" 
      id="msg-{{item.id}}"
      class="message-item {{item.role === 'user' ? 'user' : 'ai'}}"
    >
      <view class="avatar ai" wx:if="{{item.role === 'ai'}}">
        <image class="avatar-image" src="/images/biographer_avatar.jpg" mode="aspectFill" />
      </view>
      <view class="message-content">
        <view class="message-text">{{item.content}}</view>
        <text class="message-time">{{item.time}}</text>
      </view>
      <view class="avatar user" wx:if="{{item.role === 'user'}}">
        <image 
          wx:if="{{userAvatar}}" 
          class="avatar-image" 
          src="{{userAvatar}}" 
          mode="aspectFill" 
          binderror="onUserAvatarError"
        />
        <view wx:else class="avatar-default">
          <text class="avatar-initial">{{userNickName ? userNickName.charAt(0) : '用'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{isLoading}}" class="message-item ai">
      <view class="avatar ai">
        <image class="avatar-image" src="/images/biographer_avatar.jpg" mode="aspectFill" />
      </view>
      <view class="message-content">
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>

    <view wx:if="{{suggestedQuestions.length > 0}}" class="question-suggestions-area">
      <view class="question-suggestions">
        <view class="suggestions-header">
          <view class="ai-avatar-small">
            <image class="avatar-image-small" src="/images/biographer_avatar.jpg" mode="aspectFill" />
          </view>
          <text class="suggestions-title">我们可以聊聊这些话题：</text>
          <view class="change-question-btn" bindtap="onRefreshQuestions">
            <text class="change-btn-text">换一批</text>
          </view>
        </view>
        <view class="suggestions-list">
          <view 
            wx:for="{{suggestedQuestions}}" 
            wx:key="index" 
            class="suggestion-item"
            bindtap="onSelectQuestion"
            data-question="{{item}}"
          >
            <text class="suggestion-text">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <view id="msg-bottom" class="scroll-bottom-anchor"></view>
  </scroll-view>

  <view class="input-area">
    <view wx:if="{{inputMode === 'voice'}}" class="voice-input-area">
      <view 
        class="voice-btn {{isRecording ? 'recording' : ''}}"
        bindtouchstart="onTouchStart"
        bindtouchend="onTouchEnd"
        bindtouchcancel="onTouchCancel"
        bindmousedown="onMouseDown"
        bindmouseup="onMouseUp"
      >
        <text class="voice-text">{{isRecording ? recordingDuration + '秒' : '按住说话'}}</text>
      </view>
    </view>
    
    <view wx:else class="text-input-area">
      <input 
        class="input" 
        placeholder="说说您的故事..." 
        placeholder-class="input-placeholder"
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="onSend"
      />
      <button class="send-btn" bindtap="onSend" disabled="{{!inputText}}">发送</button>
    </view>
    
    <view class="input-right-actions">
      <view class="action-btn mode-toggle" bindtap="onToggleInputMode">
        <view wx:if="{{inputMode === 'text'}}" class="icon-mic-container">
          <view class="mic-icon-wrapper">
            <view class="mic-track"></view>
            <view class="mic-arc"></view>
            <view class="mic-line"></view>
          </view>
        </view>
        <view wx:else class="icon-text-btn">
          <text class="text-icon">字</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showVoiceTutorial}}" class="tutorial-overlay" bindtap="onCloseVoiceTutorial">
    <view class="tutorial-content" catchtap="stopPropagation">
      <view class="tutorial-icon">
        <view class="tutorial-mic"></view>
      </view>
      <text class="tutorial-title">语音输入教程</text>
      <text class="tutorial-desc">按住下方按钮说话，松开后自动发送</text>
      <view class="tutorial-hand">
        <view class="finger"></view>
      </view>
      <button class="tutorial-close-btn" bindtap="onCloseVoiceTutorial">我知道了</button>
    </view>
  </view>

  <view wx:if="{{showTestElders}}" class="test-elders-overlay" bindtap="onCloseTestElders">
    <view class="test-elders-modal" catchtap="stopPropagation">
      <view class="test-elders-header">
        <text class="test-elders-title">选择测试老人</text>
        <view class="test-elders-close" bindtap="onCloseTestElders">
          <text class="close-text">×</text>
        </view>
      </view>
      <scroll-view class="test-elders-list" scroll-y>
        <view 
          wx:for="{{testElders}}" 
          wx:key="id" 
          class="elder-item {{currentTestElder.id === item.id ? 'selected' : ''}}"
          bindtap="onSelectTestElder"
          data-elder="{{item}}"
        >
          <view class="elder-avatar">
            <text class="elder-avatar-text">{{item.avatar}}</text>
          </view>
          <view class="elder-info">
            <view class="elder-name-row">
              <text class="elder-name">{{item.name}}</text>
              <text class="elder-age">{{item.age}}岁</text>
            </view>
            <text class="elder-background">{{item.background}}</text>
            <text class="elder-desc">{{item.description}}</text>
          </view>
          <view wx:if="{{currentTestElder.id === item.id}}" class="elder-check">
            <text class="check-text">✓</text>
          </view>
        </view>
      </scroll-view>
      <view class="test-elders-footer">
        <button class="start-test-btn" bindtap="onStartTestConversation" disabled="{{!currentTestElder}}">
          <text class="start-btn-text">开始测试对话</text>
        </button>
      </view>
    </view>
  </view>

  <tutorial-guide 
    wx:if="{{showTutorial}}" 
    show="{{showTutorial}}" 
    bind:complete="onTutorialComplete" 
    bind:skip="onTutorialSkip" 
  />

  </view>
