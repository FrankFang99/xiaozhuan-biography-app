.page-container {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  background: linear-gradient(180deg, rgba(2, 4, 16, 0.7) 0%, rgba(7, 11, 31, 0.85) 40%, rgba(3, 5, 18, 0.95) 100%);
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  z-index: 2;
  padding: 80rpx 48rpx;
}

.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-container {
  width: 200rpx;
  height: 200rpx;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 2rpx solid rgba(212, 168, 83, 0.3);
}

.logo-image {
  width: 100%;
  height: 100%;
}

.logo-svg {
  width: 120rpx;
  height: 120rpx;
}

.brand-name {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
  letter-spacing: 8rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
}

.decoration-line {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, rgba(212, 168, 83, 0.6), transparent);
  margin-bottom: 48rpx;
}

.welcome-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 4rpx;
  line-height: 1.6;
  text-align: center;
  max-width: 600rpx;
}

.footer-area {
  width: 100%;
  max-width: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 48rpx 60rpx;
  z-index: 2;
}

.login-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  width: 100%;
  margin-bottom: 16rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn:active {
  background: rgba(212, 168, 83, 0.15);
  border-color: rgba(212, 168, 83, 0.5);
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212, 168, 83, 0.2) 0%, rgba(212, 168, 83, 0.05) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  position: relative;
}

.avatar-icon::before {
  content: '';
  position: absolute;
  top: 18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
}

.avatar-icon::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 0 0 18rpx 18rpx;
  border-top: none;
}

.nickname-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 48rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  color: #ffffff;
  text-align: center;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 56rpx;
  box-shadow: 0 12rpx 36rpx rgba(7, 193, 96, 0.35);
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 18rpx rgba(7, 193, 96, 0.25);
}

.wechat-icon {
  width: 56rpx;
  height: 56rpx;
}

.wechat-icon .circle {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon .dot {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  background: #ffffff;
  border-radius: 50%;
}

.wechat-icon .dot-1 {
  top: 14rpx;
  left: 14rpx;
}

.wechat-icon .dot-2 {
  top: 14rpx;
  right: 14rpx;
}

.wechat-icon .dot-3 {
  bottom: 18rpx;
  left: 50%;
  transform: translateX(-50%);
}

.login-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.login-btn.disabled {
  background: rgba(7, 193, 96, 0.4);
  box-shadow: none;
}

.login-btn.disabled .login-text {
  opacity: 0.5;
}

.agreement-check {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx;
  width: 100%;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: linear-gradient(135deg, #d4a853 0%, #c73e3a 100%);
  border-color: transparent;
}

.check-icon {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  flex: 1;
  line-height: 1.4;
}

.agreement-text .link {
  color: rgba(212, 168, 83, 0.6);
}