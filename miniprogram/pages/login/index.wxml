<view class="page-container">
  <image class="bg-image" src="https://images.unsplash.com/photo-1444703686981-a3abbc4d4fe3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" mode="aspectFill"></image>
  <view class="bg-overlay"></view>
  
  <view class="content">
    <view class="brand-area">
      <view class="logo-container">
        <image class="logo-image" src="/images/biographer_avatar.jpg" mode="aspectFill" />
      </view>
      <text class="brand-name">小传</text>
      <text class="brand-slogan">您的专属传记作者</text>
    </view>
    
    <view class="decoration-line"></view>
    
    <text class="welcome-text">把人生故事讲给孩子听</text>
  </view>

  <view class="footer-area">
    <view class="login-form">
      <button 
        class="avatar-btn" 
        open-type="chooseAvatar" 
        bindchooseavatar="onChooseAvatar"
      >
        <image wx:if="{{avatarUrl}}" class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
        <view wx:else class="avatar-placeholder">
          <view class="avatar-icon"></view>
        </view>
      </button>
      
      <input 
        class="nickname-input" 
        type="nickname" 
        placeholder="请输入昵称" 
        value="{{nickName}}"
        bindinput="onNicknameInput"
      />
    </view>
    
    <view class="agreement-check">
      <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="toggleAgreement">
        <view wx:if="{{agreed}}" class="check-icon">✓</view>
      </view>
      <text class="agreement-text">
        我已阅读并同意
        <text class="link" bindtap="openPrivacyPage">《隐私政策》</text>
      </text>
    </view>
    
    <button 
        class="login-btn" 
        bindtap="onWechatLogin"
        disabled="{{isLoading || !agreed}}"
      >
      <view class="wechat-icon">
        <view class="circle">
          <view class="dot dot-1"></view>
          <view class="dot dot-2"></view>
          <view class="dot dot-3"></view>
        </view>
      </view>
      <text class="login-text">微信授权登录</text>
    </button>
  </view>
</view>