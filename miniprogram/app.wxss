page {
  background-color: #030512;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  font-feature-settings: 'tnum';
  -webkit-font-feature-settings: 'tnum';
}

button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
}

button::after {
  border: none;
}

input {
  border: none;
  outline: none;
}

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #030512 0%, #070b1f 30%, #0c122e 60%, #121a3d 100%);
  padding-bottom: 160rpx;
}

.glass-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx;
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
  -webkit-perspective: 1000;
  perspective: 1000;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

.glass-card-strong {
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 40rpx;
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
  -webkit-perspective: 1000;
  perspective: 1000;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

.btn-primary {
  background: linear-gradient(135deg, #c73e3a, #e74c3c, #f16c5f);
  color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  font-size: 40rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(231, 76, 60, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  font-size: 38rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.btn-gold {
  background: linear-gradient(135deg, #9a7a34, #d4a853, #e5c06f);
  color: #030512;
  border-radius: 24rpx;
  padding: 40rpx;
  font-size: 40rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(212, 168, 83, 0.3);
}

.text-white {
  color: #ffffff;
}

.text-ghost-gray {
  color: rgba(255, 255, 255, 0.8);
}

.text-ghost-muted {
  color: rgba(255, 255, 255, 0.6);
}

.text-ghost-faint {
  color: rgba(255, 255, 255, 0.4);
}

.text-gold {
  color: #e5c06f;
}

.text-rose {
  color: #e74c3c;
}

.text-shadow-glow {
  text-shadow: 0 0 30rpx rgba(212, 168, 83, 0.6);
}

.font-serif {
  font-family: 'Noto Serif SC', 'Microsoft YaHei', serif;
}

.font-bold {
  font-weight: 600;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

@keyframes fade-up {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slide-in {
  from { opacity: 0; transform: translateX(-20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes scale-in {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse-glow {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

@keyframes star-birthday {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.5); opacity: 0.9; }
}

.animate-twinkle {
  animation: twinkle 3s ease-in-out infinite;
}

.animate-float {
  animation: float 4s ease-in-out infinite;
}

.animate-fade-up {
  animation: fade-up 0.6s ease-out forwards;
}

.animate-slide-in {
  animation: slide-in 0.5s ease-out forwards;
}

.animate-scale-in {
  animation: scale-in 0.4s ease-out forwards;
}

.animate-pulse-glow {
  animation: pulse-glow 4s ease-in-out infinite;
}

.animate-star-birthday {
  animation: star-birthday 2.5s ease-in-out infinite;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.mt-4 { margin-top: 32rpx; }
.mt-6 { margin-top: 48rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mb-6 { margin-bottom: 48rpx; }

.gap-4 { gap: 32rpx; }
.gap-6 { gap: 48rpx; }

.text-xl { font-size: 48rpx; }
.text-lg { font-size: 40rpx; }
.text-sm { font-size: 32rpx; }
.text-xs { font-size: 28rpx; }
.w-full { width: 100%; }
.block { display: block; }
