.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  transition: all 0.3s ease;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  transition: transform 0.3s ease;
}

.tab-text {
  font-size: 24rpx;
  color: #999999;
  transition: color 0.3s ease;
}

.tab-item.active .tab-text {
  color: #d4a853;
}

.icon-chat {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.chat-bubble {
  width: 36rpx;
  height: 32rpx;
  border: 3rpx solid #999999;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
  position: absolute;
  top: 8rpx;
  left: 6rpx;
}

.tab-item.active .chat-bubble {
  border-color: #d4a853;
}

.chat-bubble-small {
  width: 24rpx;
  height: 20rpx;
  border: 3rpx solid #999999;
  border-radius: 10rpx 10rpx 4rpx 10rpx;
  position: absolute;
  top: 22rpx;
  right: 2rpx;
}

.tab-item.active .chat-bubble-small {
  border-color: #d4a853;
}

.icon-letter {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.letter-envelope {
  width: 36rpx;
  height: 28rpx;
  border: 3rpx solid #999999;
  border-top: none;
  border-radius: 0 0 6rpx 6rpx;
  position: absolute;
  top: 14rpx;
  left: 6rpx;
}

.tab-item.active .letter-envelope {
  border-color: #d4a853;
}

.letter-flap {
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-top: 14rpx solid #999999;
  position: absolute;
  top: 8rpx;
  left: 6rpx;
}

.tab-item.active .letter-flap {
  border-top-color: #d4a853;
}

.letter-line {
  width: 20rpx;
  height: 2rpx;
  background: #999999;
  position: absolute;
  top: 26rpx;
  left: 14rpx;
}

.tab-item.active .letter-line {
  background: #d4a853;
}

.icon-my {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.my-circle {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #999999;
  border-radius: 50%;
  position: absolute;
  top: 6rpx;
  left: 6rpx;
}

.tab-item.active .my-circle {
  border-color: #d4a853;
}

.my-head {
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #999999;
  border-radius: 50%;
  position: absolute;
  top: 12rpx;
  left: 18rpx;
}

.tab-item.active .my-head {
  border-color: #d4a853;
}

.my-body {
  width: 20rpx;
  height: 14rpx;
  border: 3rpx solid #999999;
  border-top: none;
  border-radius: 0 0 10rpx 10rpx;
  position: absolute;
  top: 22rpx;
  left: 14rpx;
}

.tab-item.active .my-body {
  border-color: #d4a853;
}