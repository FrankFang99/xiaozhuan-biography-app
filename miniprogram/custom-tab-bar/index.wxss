.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  transition: all 0.3s ease;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  transition: transform 0.3s ease;
}

.tab-text {
  font-size: 24rpx;
  color: #999999;
  transition: color 0.3s ease;
}

.tab-item.active .tab-text {
  color: #d4a853;
}

.icon-chat {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.chat-bubble {
  width: 40rpx;
  height: 36rpx;
  background: #999999;
  border-radius: 4rpx 4rpx 4rpx 16rpx;
  position: absolute;
  top: 6rpx;
  left: 4rpx;
}

.tab-item.active .chat-bubble {
  background: #d4a853;
}

.chat-bubble-small {
  width: 20rpx;
  height: 18rpx;
  background: #999999;
  border-radius: 4rpx 4rpx 4rpx 10rpx;
  position: absolute;
  top: 18rpx;
  right: 0;
}

.tab-item.active .chat-bubble-small {
  background: #d4a853;
}

.icon-letter {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.letter-envelope {
  width: 40rpx;
  height: 28rpx;
  background: #999999;
  border-radius: 4rpx;
  position: absolute;
  top: 10rpx;
  left: 4rpx;
}

.tab-item.active .letter-envelope {
  background: #d4a853;
}

.letter-flap {
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-top: 16rpx solid #999999;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
}

.tab-item.active .letter-flap {
  border-top-color: #d4a853;
}

.icon-my {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.my-circle {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #999999;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
}

.tab-item.active .my-circle {
  border-color: #d4a853;
}

.my-inner {
  width: 16rpx;
  height: 16rpx;
  background: #999999;
  border-radius: 50%;
  position: absolute;
  top: 16rpx;
  left: 16rpx;
}

.tab-item.active .my-inner {
  background: #d4a853;
}